# Gaming Proxy Configuration

# Server port
PORT=3000

# Comma-separated list of game servers
# Format: host:port,host:port
GAME_SERVERS=game1.example.com:7777,game2.example.com:7777,game3.example.com:7777

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Connection pool size
POOL_SIZE=100

# Request timeout in milliseconds
REQUEST_TIMEOUT=5000

# Enable compression
ENABLE_COMPRESSION=true